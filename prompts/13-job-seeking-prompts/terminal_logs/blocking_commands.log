import sys
import os
import pypdf
from xhtml2pdf import pisa

def generate_pdf(html_content, output_filename):
    with open(output_filename, "wb") as f:
        pisa_status = pisa.CreatePDF(html_content, dest=f)
    if pisa_status.err:
        return False
    return True

